# Database
DATABASE_URL=sqlite:///data/db/pipeline.db

# Redis
REDIS_PASSWORD=  # Set a strong random password, e.g.: openssl rand -hex 32
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Paths
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/outputs
MODEL_CACHE_DIR=/app/data/models
ALLOWED_SOURCE_ROOTS=["/mnt/nas","/app/data/uploads"]

# Security
REQUIRE_AUTH=false
API_TOKEN=
WORKER_LOG_PATH=/app/data/logs/worker.log

# GPU
CUDA_VISIBLE_DEVICES=0

# Logging
LOG_LEVEL=info
